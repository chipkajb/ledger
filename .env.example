# ─── Ledger — Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local and fill in your own values.
#   cp .env.example .env.local

# ─── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# For local dev this can be a relative path. For Docker, use an absolute path
# that maps to your mounted volume (e.g. /data/ledger.db).
DATABASE_URL=./ledger.db

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# A long, random secret used to sign session tokens. MUST be at least 32 chars.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# The canonical URL of your deployment (no trailing slash).
# For local dev: http://localhost:3000
# For production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# ─── Admin Credentials ────────────────────────────────────────────────────────
# The email address used to log in to the app.
ADMIN_EMAIL=admin@ledger.local

# Plain-text password used during first-run seeding.
# After the seed runs this is hashed and stored in the database; the plain-text
# value is no longer needed and is safe to remove from your env file.
# NEVER commit a real password here — keep it only in your local .env.local.
ADMIN_PASSWORD=
